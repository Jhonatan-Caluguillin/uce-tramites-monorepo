{
  "name": "audit-service",
  "projectType": "application",
  "sourceRoot": "apps/audit-service/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t audit-service ."
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python src/main.py"
      }
    }
  }
}