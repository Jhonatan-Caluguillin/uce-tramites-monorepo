{
  "name": "students-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/students-service/src",
  "targets": {
    "docker-up": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker/docker-compose.local.yml up -d students-service"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker/docker-compose.local.yml build students-service"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo \"no tests yet for students-service\""
      }
    }
  }
}
